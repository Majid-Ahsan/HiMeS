# Cognee Configuration Template
# Kopiere diese Datei zu .env und fülle die echten Werte aus
# WICHTIG: .env darf NICHT committed werden (steht in .gitignore)

# LLM Configuration
# Anthropic API-Key (klassisch sk-ant-api03-...)
# WICHTIG: OAuth-Tokens (sk-ant-oat01-) funktionieren NICHT mit Cognee
# Tool-Use ist erforderlich, das geht nur mit klassischen API-Keys
LLM_API_KEY=sk-ant-api03-YOUR_KEY_HERE
LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5-20251001

# Optional: ANTHROPIC_API_KEY
# Cognee liest LLM_API_KEY und reicht es korrekt durch (validiert mit Cognee 1.0.3).
# Manche transitive Dependencies (anthropic-SDK direkt, LiteLLM) lesen
# ANTHROPIC_API_KEY als Default-Fallback. Falls du Cognee unabhängig
# extern aufrufst und den SDK ohne explizit übergebenen Key nutzt,
# kann diese Variable zusätzlich gesetzt werden.
# Für reines Cognee-Setup: nicht nötig.
# ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# Workaround für Cognee 1.0.3 Bug
# Cognees Anthropic-Adapter reicht max_tokens nicht durch
# Ohne diesen Wert: 128s Timeout statt klarer Fehlermeldung
# Bei Cognee-Update prüfen ob noch nötig
LLM_ARGS={"max_tokens": 4096}

# Embedding Configuration (lokal via Fastembed)
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# Database Configuration (alle file-based, keine externe Infrastruktur)
DB_PROVIDER=sqlite
VECTOR_DB_PROVIDER=lancedb
GRAPH_DATABASE_PROVIDER=kuzu
