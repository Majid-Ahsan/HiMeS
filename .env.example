# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_ALLOWED_USERS=123456789  # comma-separated user IDs

# Claude Code OAuth Token (generieren: claude setup-token auf dem VPS als User ali)
# Gültigkeit: 1 Jahr, danach erneuern
CLAUDE_CODE_OAUTH_TOKEN=

# Claude Code
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TURNS=10
CLAUDE_MAX_TOOL_CALLS=5

# MCP
MCP_CONFIG_PATH=/app/config/mcp_config.json

# Memory
MEMORY_FILE_PATH=/app/data/MEMORY.md

# Health endpoint
HEALTH_PORT=8080

# Notion MCP
NOTION_TOKEN=your-notion-integration-token

# Deutsche Bahn API (optional — REST-API-Tools funktionieren auch ohne)
DB_API_CLIENT_ID=
DB_API_CLIENT_SECRET=

# Logging
LOG_LEVEL=INFO
LOG_FILE_PATH=/app/logs/himes.log
