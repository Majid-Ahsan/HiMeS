{
  "mcpServers": {
    "himes-tools": {
      "command": "python",
      "args": ["-m", "himes_mcp.server"],
      "cwd": "/app",
      "env": {
        "MEMORY_FILE_PATH": "/app/data/MEMORY.md",
        "NOTION_TOKEN": "${NOTION_TOKEN}"
      }
    },
    "notion": {
      "command": "npx",
      "args": ["-y", "easy-notion-mcp"],
      "env": {
        "NOTION_API_KEY": "${NOTION_TOKEN}"
      }
    },
    "things3": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://things-ahsan.duckdns.org/mcp"
      ]
    },
    "caldav": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://caldav-ahsan.duckdns.org/sse"
      ]
    },
    "weather": {
      "command": "npx",
      "args": ["-y", "@dangahagan/weather-mcp@latest"],
      "env": {
        "ENABLED_TOOLS": "full"
      }
    },
    "time": {
      "command": "python",
      "args": ["-m", "mcp_server_time"],
      "env": {
        "LOCAL_TIMEZONE": "Europe/Berlin"
      }
    }
  }
}
